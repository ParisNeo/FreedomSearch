{
    "ros.distro": "noetic",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.lollms/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/.lollms/**": true
    },
    "python.analysis.exclude": [
        "**/.lollms/**",
        "**/venv/**",
        "**/node_modules/**"
    ],
    "python.analysis.ignore": [
        "**/.lollms/**",
        "**/venv/**",
        "**/node_modules/**"
    ],
    "isort.check": false,
    "isort.importStrategy": "useBundled",
    "python.analysis.indexing": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "never"
    }
}